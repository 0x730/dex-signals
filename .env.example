# Database Configuration
DB_HOST=127.0.0.1
DB_USER=change_me
DB_PASSWORD=change_me
DB_NAME=signals
DB_PORT=3306

PORT=4100
HOST=127.0.0.1
NODE_ENV=development

# GeckoTerminal Settings
GECKO_BASE_URL=https://api.geckoterminal.com
GECKO_NETWORK=base
GECKO_ENDPOINT=pools
GECKO_SORT=h24_volume_usd_desc
GECKO_FETCH_INTERVAL_MS=180000
GECKO_MAX_PAGES=3

# GeckoTerminal API Rate Limiting
API_RATE_LIMIT_MS=5000
GECKO_MAX_RETRIES=3
GECKO_INITIAL_RETRY_DELAY=10000
GECKO_RATE_LIMIT_BACKOFF=120000
GECKO_MAX_TOKENS_PER_RUN=50
GECKO_MAX_CONSECUTIVE_RATE_LIMITS=3

# Dextools Settings
DEXTOOLS_BASE_URL=https://www.dextools.io
DEXTOOLS_FETCH_INTERVAL_MS=60000
MAX_DEXTOOLS_TOKENS=30
DEXTOOLS_SKIP_INTERVAL_MS=60000

NOT_OLDER_DAYS=0.1

# DexScreener Configuration
DEXSCREENER_FETCH_INTERVAL_MS=60000

# GeckoScore Worker Configuration
GECKO_SCORE_FETCH_INTERVAL_MS=300000
MIN_GT_SCORE=0
SCORE_SKIP_INTERVAL_MINUTES=10

# Score Worker Configuration
SCORE_WORKER_INTERVAL_MS=30000
SCORE_THRESHOLD=50
HIGH_SCORE_THRESHOLD=50

CLEANUP_WORKER_INTERVAL_MS=120000

# Thresholds
MIN_LIQUIDITY=5000
MIN_DEXT_SCORE=0

# API keys
MANAGER_API_KEY=replace_with_manager_secret
BASESCAN_API_KEY=replace_with_key
SCRAPERAPI_KEY=replace_with_key
# OPENAI_API_KEY=replace_with_key

DOWNLOAD_SCORE_THRESHOLD=3
OPENAI_SKIP_INTERVAL_MS=180000

# Mythril and Slither
MYTHRIL_SCORE_THRESHOLD=5
MYTHRIL_SKIP_INTERVAL_MS=300000
MYTHRIL_INTERVAL_MS=3600000
MYTHRIL_TOKENS_LIMIT=5
MYTHRIL_SOLC_VERSION=0.8.0

SLITHER_SCORE_THRESHOLD=3
SLITHER_SKIP_INTERVAL_MS=300000
SLITHER_TOKENS_LIMIT=10
SLITHER_INTERVAL_MS=3600000

TOKENSNIFFER_FETCH_INTERVAL_MS=180000
MAX_TOKENSNIFFER_TOKENS=5

GOPLUS_FETCH_INTERVAL_MS=30000
MAX_GOPLUS_TOKENS=20

# Puppeteer Token Sniffer
PUPPETEER_REQUEST_DELAY_MS=5000
PUPPETEER_MAX_RETRIES=3
PUPPETEER_RETRY_DELAY_MS=2000

# Paper Trading
PAPER_TRADING_UPDATE_INTERVAL_MS=10000
EXTERNAL_PAPER_TRADING_SIGNALS_URL=

# Directories
SOLIDITY_DIR=./data/solidity_codes
TEMP_DIR=./data/temp
