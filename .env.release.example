# Local public release configuration.
# Copy to .env.release.local and fill values. Never commit .env.release.local.

PUBLIC_RELEASE_OUT=/tmp/bots-public
PUBLIC_RELEASE_VERSION=auto
PUBLIC_GITHUB_REPO=OWNER/REPO
PUBLIC_RELEASE_FORCE=true

# Required if GitHub CLI (`gh`) is not installed/authenticated.
# Needs repo creation, contents push, and release creation permissions.
# GITHUB_TOKEN=replace_with_github_token
